# Standard Gitignore for Full-Stack App

# Root Node Modules (if any)
node_modules/
.npm/

# Backend
backend/node_modules/
backend/.env
backend/dist/
backend/prisma/migrations/
backend/prisma/generated/
backend/package-lock.json

# Frontend
frontend/node_modules/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/dist/
frontend/package-lock.json

# OS Specific
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Editor Specific
.vscode/
.idea/
*.swp
*.swo
